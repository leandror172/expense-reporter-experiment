# Excel files
*.xlsx
*.BACKUP.xlsx

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Go build artefacts
*.exe
.gotmp/
.tmp/

# Test outputs
*_output.txt
test_output.txt

# Reports & batch run artefacts
*report*.txt
expenses_failed_*.csv
expenses_rollover_*.csv
categorized_expenses_*.csv

# Classification training data (personal expense data — never commit)
data/classification/*.json
data/classification/*.csv
data/classification/*.bak-*
!data/classification/algorithm_parameters.json

# Revenue/income taxonomy proposal (payslip-structure fragments — personal)
.claude/scratch/taxonomy-revenue-proposal.json
# Real taxonomy (derived from personal Referência sheet — reveals personal categories)
expense-reporter/config/taxonomy.json

# Claude Code local data (secrets, personal paths, backups)
.claude/local/

# Claude Code local settings (personal permissions allowlist, remote env ID — machine-specific)
.claude/settings.local.json

# Transient fix scripts and one-off reports (moved to docs/archive/transients/)
docs/archive/transients/

# Backup files
*.bak
expense-reporter/*.bak
# Timestamped backups (*.bak-YYYYMMDD-HHMMSS) — plain *.bak does NOT match these.
# Global rule so personal-data backups (taxonomy, logs) never leak regardless of dir.
*.bak-*
# LibreOffice/OpenOffice lock files (appear when a generated workbook is open)
.~lock.*#

# Acceptance test results (drift tracking JSON)
expense-reporter/test/results/
expense-reporter/expense-reporter

# Workbook structural dump — contains real expense cell values (sensitive)
.claude/workbook-dump/
# Layer 2 visual notes — may contain rendered expense values (sensitive)
.claude/workbook-visual-notes.md
.claude/workbook-screenshots/
# workbook-inspect build output
expense-reporter/workbook-inspect

# Runtime classification logs (personal expense data — never commit).
# Anchored to repo root + expense-reporter/ so test fixtures under test/ are NOT ignored.
/classified.csv
/review-*.html
/expense-reporter/classifications.jsonl
/expense-reporter/expenses_log.jsonl
/expense-reporter/expenses_log-*.jsonl
/expense-reporter/expenses_log.jsonl.bak-*

# Session transcript dumps + local Claude scaffolding (personal paths, not source)
/*.txt
/expense-reporter/*.txt
/.claude/.claude/
/.claude/settings.json
/.claude/expense-report-career-positioning-report-*.md
/.claude/scratch/template-builder/template-builder
/.claude/skills/**/*.bak-p4
/.claude/workbook-template/backup-*/
